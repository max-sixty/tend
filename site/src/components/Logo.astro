---
interface Props {
  size?: number;
  /** Render the static assembled mark — no entrance animation, no breath. For the header lockup etc. */
  static?: boolean;
}
const { size = 220, static: isStatic = false } = Astro.props;
const width = Math.round((size * 200) / 256);
---

<svg
  class:list={["logo-mark", { "is-static": isStatic }]}
  width={width}
  height={size}
  viewBox="0 0 200 256"
  xmlns="http://www.w3.org/2000/svg"
  aria-label="Tend"
  role="img"
>
  <g class="logo-grow">
    <!-- Stem: a thick round-capped stroke whose centreline runs from the
         base of the hook up to the neck. Drawn via stroke-dashoffset, so it
         reads as a shoot pushing up out of the ground and curling at the base.
         pathLength="1" normalises the dash maths to be length-independent. -->
    <path
      class="stem"
      d="M 137 217 C 116 218, 101 211, 100 187 L 100 92"
      fill="none"
      stroke="currentColor"
      stroke-width="17"
      stroke-linecap="round"
      pathLength="1"
    ></path>

    <!-- Side leaves: unfurl outward from the neck — thin crescents that
         lift a touch then droop to their tip. -->
    <path
      class="leaf-left"
      d="M 97 93 C 74 90, 47 96, 26 114 C 47 105, 73 100, 97 100 Z"
    ></path>
    <path
      class="leaf-right"
      d="M 103 93 C 126 90, 153 96, 174 114 C 153 105, 127 100, 103 100 Z"
    ></path>

    <!-- Central leaf: opens upward from the neck to its point. -->
    <path
      class="leaf-top"
      d="M 100 92 C 80 78, 74 42, 100 10 C 126 42, 120 78, 100 92 Z"
    ></path>
  </g>
</svg>

<style>
  .logo-mark {
    display: block;
    overflow: visible;
    color: var(--oak, #b5a48a);
  }
  .logo-mark .leaf-top,
  .logo-mark .leaf-left,
  .logo-mark .leaf-right {
    fill: currentColor;
  }

  /* Each piece's growth anchor, in viewBox coordinates. */
  .logo-mark .leaf-top {
    transform-box: view-box;
    transform-origin: 100px 92px;
  }
  .logo-mark .leaf-left {
    transform-box: view-box;
    transform-origin: 97px 96px;
  }
  .logo-mark .leaf-right {
    transform-box: view-box;
    transform-origin: 103px 96px;
  }

  /* ---------------------------------------------------------------
   * Entrance: the plant builds itself from nothing.
   *   1. the stem pushes up out of the ground, curling at the base
   *   2. the two side leaves unfurl outward from the neck (a touch of
   *      back-ease overshoot so they "spring" open)
   *   3. the central leaf opens upward to its point
   * The phases overlap so it reads as one continuous growth, and the
   * settled state is exactly what the static mark renders.
   * --------------------------------------------------------------- */

  .logo-mark:not(.is-static) .stem {
    stroke-dasharray: 1;
    animation: stem-grow 0.85s cubic-bezier(0.16, 1, 0.3, 1) 0.15s both;
  }
  @keyframes stem-grow {
    from { stroke-dashoffset: 1; }
    to   { stroke-dashoffset: 0; }
  }

  .logo-mark:not(.is-static) .leaf-left {
    animation: leaf-left-unfurl 0.7s cubic-bezier(0.34, 1.4, 0.64, 1) 0.8s both;
  }
  @keyframes leaf-left-unfurl {
    from { transform: scale(0) rotate(26deg); }
    to   { transform: none; }
  }
  .logo-mark:not(.is-static) .leaf-right {
    animation: leaf-right-unfurl 0.7s cubic-bezier(0.34, 1.4, 0.64, 1) 0.87s both;
  }
  @keyframes leaf-right-unfurl {
    from { transform: scale(0) rotate(-26deg); }
    to   { transform: none; }
  }

  .logo-mark:not(.is-static) .leaf-top {
    animation: leaf-top-grow 0.8s cubic-bezier(0.18, 1, 0.32, 1) 1.05s both;
  }
  @keyframes leaf-top-grow {
    from { transform: scaleX(0.38) scaleY(0); }
    to   { transform: none; }
  }

  /* Gentle continuous breath once assembled. */
  .logo-mark:not(.is-static) .logo-grow {
    transform-box: view-box;
    transform-origin: 100px 220px;
    animation: logo-breathe 7s ease-in-out 2.05s infinite;
  }
  @keyframes logo-breathe {
    0%, 100% { transform: scale(1); }
    50%      { transform: scale(1.014); }
  }

  @media (prefers-reduced-motion: reduce) {
    .logo-mark .stem,
    .logo-mark .leaf-left,
    .logo-mark .leaf-right,
    .logo-mark .leaf-top,
    .logo-mark .logo-grow {
      animation: none;
    }
    .logo-mark .stem {
      stroke-dasharray: none;
    }
  }
</style>
