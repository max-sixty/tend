---
interface Props {
  size?: number;
}
const { size = 168 } = Astro.props;
---

<svg
  class="seedling"
  width={size}
  height={(size * 1.1) | 0}
  viewBox="-10 0 220 240"
  xmlns="http://www.w3.org/2000/svg"
  aria-label="Tend"
  role="img"
>
  <!-- Stem: vertical line from crossbar height down to the curl -->
  <path
    class="stroke stem"
    d="M 100 64 L 100 195 Q 100 220 125 220"
    fill="none"
  />

  <!-- Crossbar veins (visible only inside the blades, so they read as midribs) -->
  <path class="stroke vein vein-left"  d="M 100 96 Q 70 108 28 124" fill="none" />
  <path class="stroke vein vein-right" d="M 100 96 Q 130 108 172 124" fill="none" />

  <!-- Left crossbar leaf blade — broader, drooping outward like the source logo -->
  <path
    class="blade blade-left"
    d="M 100 96
       Q 60 76 18 110
       Q 35 152 100 96 Z"
  />

  <!-- Right crossbar leaf blade -->
  <path
    class="blade blade-right"
    d="M 100 96
       Q 140 76 182 110
       Q 165 152 100 96 Z"
  />

  <!-- Top bud: a slender leaf rising from the crown -->
  <path class="stroke bud-vein" d="M 100 64 L 100 18" fill="none" />
  <path
    class="blade bud"
    d="M 100 18
       Q 86 30 92 60
       Q 100 70 108 60
       Q 114 30 100 18 Z"
  />
</svg>

<style>
  .seedling {
    display: block;
    overflow: visible;
    /* Oak / sand brand color for the strokes */
    --leaf-fill: #b5a48a;
    --vein-color: #8e7d63;
  }

  .stroke {
    stroke: var(--vein-color);
    stroke-width: 4;
    stroke-linecap: round;
    stroke-linejoin: round;
    fill: none;
  }

  .stem { stroke-width: 7; }
  .vein, .bud-vein { stroke-width: 3; opacity: 0.7; }

  .blade {
    fill: var(--leaf-fill);
  }

  /* ----- Animation ----- */

  /* Stem draws upward */
  .stem {
    stroke-dasharray: 180;
    stroke-dashoffset: 180;
    animation: draw-up 0.6s cubic-bezier(0.4, 0, 0.2, 1) 0.1s forwards;
  }

  /* Crossbar veins draw outward, after the stem */
  .vein-left, .vein-right {
    stroke-dasharray: 70;
    stroke-dashoffset: 70;
    animation: draw 0.35s ease-out 0.55s forwards;
  }

  /* Crossbar leaf blades unfurl from the central crown point */
  .blade-left {
    transform-origin: 100px 96px;
    transform: scale(0);
    animation: unfurl-left 0.55s cubic-bezier(0.34, 1.4, 0.64, 1) 0.65s forwards;
  }
  .blade-right {
    transform-origin: 100px 96px;
    transform: scale(0);
    animation: unfurl-right 0.55s cubic-bezier(0.34, 1.4, 0.64, 1) 0.7s forwards;
  }

  /* Bud vein, then bud opens */
  .bud-vein {
    stroke-dasharray: 50;
    stroke-dashoffset: 50;
    animation: draw 0.3s ease-out 0.85s forwards;
  }
  .bud {
    transform-origin: 100px 64px;
    transform: scale(0);
    animation: open-bud 0.5s cubic-bezier(0.34, 1.4, 0.64, 1) 1s forwards;
  }

  @keyframes draw-up {
    to { stroke-dashoffset: 0; }
  }
  @keyframes draw {
    to { stroke-dashoffset: 0; }
  }
  @keyframes unfurl-left {
    0%   { transform: scale(0) rotate(15deg); }
    100% { transform: scale(1) rotate(0); }
  }
  @keyframes unfurl-right {
    0%   { transform: scale(0) rotate(-15deg); }
    100% { transform: scale(1) rotate(0); }
  }
  @keyframes open-bud {
    0%   { transform: scaleY(0) scaleX(0.3); }
    100% { transform: scaleY(1) scaleX(1); }
  }

  @media (prefers-reduced-motion: reduce) {
    .stem, .vein, .vein-left, .vein-right, .bud-vein {
      stroke-dasharray: none;
      stroke-dashoffset: 0;
      animation: none;
    }
    .blade, .bud, .blade-left, .blade-right {
      transform: none;
      animation: none;
    }
  }
</style>
