---
// Variant C — "grow & draw": a fine pen-stroke traces the mark's whole outer
// line in one continuous stroke, from the foot upward; the warm colour floods
// in just behind the pen (revealed by a fat invisible stroke along the same
// path), so the colour propagates around the mark with the line — not as a
// flat waterline and not in piece-by-piece chunks. The pen then fades. The
// settled silhouette is the logo.
interface Props {
  size?: number;
  static?: boolean;
}
const { size = 220, static: isStatic = false } = Astro.props;
const width = Math.round((size * 438) / 564);
const uid = Math.random().toString(36).slice(2, 9);
const floodMask = `lb-flood-${uid}`;

// The whole assembled mark as one silhouette, ordered to start at the foot.
const markD =
  "M 261.1 557.5 C 286.9 566.3 324.1 564.9 349.1 554.2 C 350.67 553.53 352.23 552.87 353.8 552.2 C 351.73 545.67 349.67 539.13 347.6 532.6 C 344.1 521.8 341.1 512.8 340.9 512.5 C 340.6 512.3 337.5 513.2 333.9 514.5 C 318.8 519.9 299.3 521.6 286.2 518.5 C 260.8 512.5 246.6 492.6 243 457.9 C 241.6 444.1 241.7 335.2 243.1 323.5 C 247.5 287.7 268.6 258.1 305.4 236 C 325.2 224.1 353.2 214.7 375.5 212.5 C 381.5 212 381.4 212 369.5 216.3 C 341.2 226.6 322.5 236.4 304.5 250.5 C 294.6 258.2 276.8 276.7 277.2 278.8 C 277.6 280.9 291.2 285.7 302.3 287.6 C 313.3 289.5 331.1 289 341 286.5 C 350.1 284.2 366.4 276.1 374.9 269.7 C 392.9 256.1 414.5 231.1 433.2 202.1 C 434.8 199.57 436.4 197.03 438 194.5 C 437.07 194.1 436.13 193.7 435.2 193.3 C 433.6 192.7 425.6 190.3 417.4 188 C 345.6 168.3 293.9 181.7 270.4 226.3 C 266.8 233.2 262 246.1 262 248.9 C 262 249.8 259 253.9 255.4 258 C 251.8 262.1 247.4 267.5 245.6 270 C 244.57 271.5 243.53 273 242.5 274.5 C 242.4 256.73 242.3 238.97 242.2 221.2 C 242.13 203.4 242.07 185.6 242 167.8 C 243.93 165.6 245.87 163.4 247.8 161.2 C 255.3 152.6 257 150.1 262 140.1 C 277.4 109.2 271.2 74.3 242.6 31.6 C 233.9 18.6 220.3 1 219.1 1 C 218.6 1 214.7 5.6 210.3 11.2 C 169.1 63.9 158.5 104.2 176.4 140.5 C 183.2 154.1 199.4 173.2 201.9 170.4 C 203.5 168.6 208 155.8 210.4 146.3 C 215.2 127.4 218.5 100.4 219.3 74 C 219.37 71.5 219.43 69 219.5 66.5 C 220.3 71.17 221.1 75.83 221.9 80.5 C 223.5 89.9 224.4 100.3 224.7 112 C 225.8 150.8 218.2 178.4 200.6 199.5 C 199.23 201.13 197.87 202.77 196.5 204.4 C 196.33 216.1 196.17 227.8 196 239.5 C 195.83 251.17 195.67 262.83 195.5 274.5 C 194.37 272.87 193.23 271.23 192.1 269.6 C 190.2 266.9 186.1 261.6 182.8 257.9 C 177.9 252.2 176.5 249.6 173.9 241.8 C 157.7 192 112.8 170.7 47.7 182 C 28.2 185.3 1 193 1 195.2 C 1 195.7 4.2 201 8.1 206.9 C 38.8 252.6 65.6 277 94.5 285.5 C 106.5 289 122.8 289.9 135.7 287.6 C 147.3 285.6 160.4 280.9 160.8 278.7 C 161 277.6 156.3 272.1 147.8 263.7 C 126.2 242 104 228.8 67.5 215.9 C 63.83 214.6 60.17 213.3 56.5 212 C 58.5 212.2 60.5 212.4 62.5 212.6 C 100.2 216.4 139.3 235 164.5 261.1 C 179.5 276.6 187.2 290.2 192.8 310.9 C 193.67 314.1 194.53 317.3 195.4 320.5 C 195.63 345 195.87 369.5 196.1 394 C 196.8 473.4 196.8 472.9 202.6 493.5 C 211.6 525 232.3 547.7 261.1 557.5 Z";
---

<svg
  class:list={["lb", { "is-static": isStatic }]}
  width={width}
  height={size}
  viewBox="0 0 438 564"
  xmlns="http://www.w3.org/2000/svg"
  aria-label="Tend"
  role="img"
>
  <defs>
    <mask id={floodMask} maskUnits="userSpaceOnUse" x="-12" y="-12" width="462" height="600">
      <!-- a fat white stroke along the mark's outline; "drawing" it (via
           stroke-dashoffset) opens the mask in a band that follows the pen -->
      <path
        class="lb-flood"
        d={markD}
        fill="none"
        stroke="#fff"
        stroke-width="92"
        stroke-linejoin="round"
        stroke-linecap="round"
        pathLength="1"
      ></path>
    </mask>
  </defs>
  <g class="lb-root">
    <path class="lb-fill" d={markD} mask={`url(#${floodMask})`}></path>
    <path
      class="lb-outline"
      d={markD}
      fill="none"
      stroke="currentColor"
      stroke-width="3.5"
      stroke-linejoin="round"
      pathLength="1"
    ></path>
  </g>
</svg>

<style>
  .lb {
    display: block;
    overflow: visible;
    color: var(--oak, #b5a48a);
  }
  .lb-fill { fill: currentColor; fill-rule: evenodd; }
  .lb-outline { fill: none; }

  /* ---- entrance: the pen glides around the outer line at a steady pace,
   * staying well ahead; the colour floods in following it; then the pen
   * fades. Unhurried — the draw is ~2.4s, the colour catches up ~0.3s later. */
  .lb:not(.is-static) .lb-flood {
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
    animation: lb-draw 3s cubic-bezier(0.35, 0.1, 0.4, 0.9) 0.4s forwards;
  }
  .lb:not(.is-static) .lb-outline {
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
    animation:
      lb-draw 2.4s cubic-bezier(0.35, 0.1, 0.4, 0.9) 0.05s forwards,
      lb-sfade 0.8s ease 2.6s forwards;
  }
  @keyframes lb-draw { to { stroke-dashoffset: 0; } }
  @keyframes lb-sfade { to { opacity: 0; } }

  /* settle: a slow, faint breath once filled */
  .lb:not(.is-static) .lb-root {
    transform-box: view-box;
    transform-origin: 215px 540px;
    animation: lb-breathe 7.5s ease-in-out 3.6s infinite;
  }
  @keyframes lb-breathe {
    0%, 100% { transform: scale(1); }
    50%      { transform: scale(1.012); }
  }

  @media (prefers-reduced-motion: reduce) {
    .lb .lb-flood, .lb .lb-outline, .lb .lb-root { animation: none; }
    .lb .lb-fill { mask: none; }
    .lb .lb-outline { display: none; }
  }
  .lb.is-static .lb-fill { mask: none; }
  .lb.is-static .lb-outline { display: none; }
</style>
