---
// Variant C — "layered": pieces grow into place (like Grow) AND each is
// outline-drawn as it arrives — the guide-stroke traces the piece's edge
// while the piece scales open, the warm fill trailing behind. Real geometry.
interface Props {
  size?: number;
  static?: boolean;
}
const { size = 220, static: isStatic = false } = Astro.props;
const width = Math.round((size * 438) / 564);

// Pieces re-cut from the traced mark with overlapping joints, so the
// assembled shape is one seamless silhouette (no thin lines at the seams).
const stemD =
  "M 213 180.1 c 0 1.8 -7 12.8 -11.9 18.8 l -4.6 5.6 -0.5 35 -0.5 35 -4.5 -6.4 -4.5 -6.4 -0.3 14.5 c -0.2 13.4 -0.1 14.9 2.3 21.3 7 18.5 6.8 15.5 7.5 96.5 0.8 79.4 0.8 78.9 6.6 99.5 9 31.5 29.7 54.2 58.5 64 25.8 8.8 63 7.4 88 -3.3 l 4.7 -2 -6.2 -19.6 c -3.5 -10.8 -6.5 -19.8 -6.7 -20.1 -0.3 -0.2 -3.4 0.7 -7 2 -15.1 5.4 -34.6 7.1 -47.7 4 -20.5 -4.8 -34.3 -19.6 -40.2 -42.8 -3.9 -15.6 -4.2 -25.4 -3.9 -115.2 0.2 -47.3 0.3 -107.5 0.1 -133.8 l -0.2 -47.7 -14.5 0 c -10 0 -14.5 0.3 -14.5 1.1 z";
const leafLeftD =
  "M 64.5 179.7 c -20.3 2.4 -35.8 5.6 -52.5 10.9 -6 1.9 -11 4 -11 4.5 0 0.6 3.2 5.9 7.1 11.8 30.7 45.7 57.5 70.1 86.4 78.6 12 3.5 28.3 4.4 41.2 2.1 11.6 -2 24.7 -6.7 25.1 -8.9 0.2 -1.1 -4.5 -6.6 -13 -15 -21.6 -21.7 -43.8 -34.9 -80.3 -47.8 l -11 -3.9 6 0.6 c 37.7 3.8 76.8 22.4 102 48.5 14.9 15.5 22.9 29.5 28.1 49.3 l 2.3 9.1 0.1 -22.8 0 -22.8 -3.2 -4.6 c -1.7 -2.5 -5.7 -7.7 -9 -11.4 -4.9 -5.7 -6.3 -8.3 -8.9 -16.1 -11.7 -36 -37.9 -57 -76.9 -61.8 -7.9 -0.9 -25.8 -1.1 -32.5 -0.3 z";
const leafRightD =
  "M 234 245.5 l 0 74.5 5 0 c 4.6 0 5 -0.2 5 -2.4 0 -4.3 5.1 -19.9 9.2 -28.5 19.1 -39 70.9 -71.5 122.3 -76.6 6 -0.5 5.9 -0.5 -6 3.8 -28.3 10.3 -47 20.1 -65 34.2 -9.9 7.7 -27.7 26.2 -27.3 28.3 0.4 2.1 14 6.9 25.1 8.8 11 1.9 28.8 1.4 38.7 -1.1 9.1 -2.3 25.4 -10.4 33.9 -16.8 18 -13.6 39.6 -38.6 58.3 -67.6 l 4.8 -7.6 -2.8 -1.2 c -1.6 -0.6 -9.6 -3 -17.8 -5.3 -71.8 -19.7 -123.5 -6.3 -147 38.3 -3.6 6.9 -8.4 19.8 -8.4 22.6 0 0.9 -3 5 -6.6 9.1 -3.6 4.1 -8 9.5 -9.8 12 l -3.1 4.5 -0.3 -51.8 -0.2 -51.7 -4 0 -4 0 0 74.5 z";
const leafTopD =
  "M 210.3 11.2 c -41.2 52.7 -51.8 93 -33.9 129.3 6.8 13.6 23 32.7 25.5 29.9 1.6 -1.8 6.1 -14.6 8.5 -24.1 4.8 -18.9 8.1 -45.9 8.9 -72.3 l 0.2 -7.5 2.4 14 c 7.3 43.5 1.7 85 -14.8 110 -2.5 3.8 -5 7.6 -5.4 8.2 -0.6 1 3.6 1.3 19.8 1.3 l 20.5 0 0 -16.1 0 -16.1 5.8 -6.6 c 7.5 -8.6 9.2 -11.1 14.2 -21.1 15.4 -30.9 9.2 -65.8 -19.4 -108.5 -8.7 -13 -22.3 -30.6 -23.5 -30.6 -0.5 0 -4.4 4.6 -8.8 10.2 z";

const pieces = [
  { cls: "stem", d: stemD },
  { cls: "leaf-l", d: leafLeftD },
  { cls: "leaf-r", d: leafRightD },
  { cls: "leaf-t", d: leafTopD },
];
---

<svg
  class:list={["lb", { "is-static": isStatic }]}
  width={width}
  height={size}
  viewBox="0 0 438 564"
  xmlns="http://www.w3.org/2000/svg"
  aria-label="Tend"
  role="img"
>
  <g class="lb-root">
    {pieces.map((p) => (
      <g class:list={["lb-piece", `lb-${p.cls}`]}>
        <path class="lb-fill" d={p.d}></path>
        <path
          class="lb-stroke"
          d={p.d}
          fill="none"
          stroke="currentColor"
          stroke-width="4"
          stroke-linejoin="round"
          pathLength="1"
        ></path>
      </g>
    ))}
  </g>
</svg>

<style>
  .lb {
    display: block;
    overflow: visible;
    color: var(--oak, #b5a48a);
  }
  .lb-fill { fill: currentColor; fill-rule: evenodd; }
  .lb-stroke { fill: none; }

  /* per-piece growth anchors */
  .lb .lb-stem { transform-box: fill-box; transform-origin: 50% 100%; }
  .lb .lb-leaf-l { transform-box: view-box; transform-origin: 196px 240px; }
  .lb .lb-leaf-r { transform-box: view-box; transform-origin: 240px 240px; }
  .lb .lb-leaf-t { transform-box: view-box; transform-origin: 210px 176px; }

  /* ---- entrance: each piece scales in while its outline traces, fill trailing ---- */
  .lb:not(.is-static) .lb-fill {
    opacity: 0;
  }
  .lb:not(.is-static) .lb-stroke {
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
  }

  /* stem: 0 - 0.95s */
  .lb:not(.is-static) .lb-stem { animation: lb-grow-stem 0.95s cubic-bezier(0.22, 1, 0.36, 1) 0s both; }
  .lb:not(.is-static) .lb-stem .lb-stroke { animation: lb-trace 0.8s cubic-bezier(0.5, 0, 0.4, 1) 0.05s forwards, lb-sfade 0.35s ease 0.78s forwards; }
  .lb:not(.is-static) .lb-stem .lb-fill { animation: lb-ink 0.4s ease 0.6s forwards; }
  @keyframes lb-grow-stem { from { transform: scaleY(0); } to { transform: none; } }

  /* left leaf: 0.65 - 1.45s */
  .lb:not(.is-static) .lb-leaf-l { animation: lb-grow 0.7s cubic-bezier(0.34, 1.3, 0.64, 1) 0.65s both; }
  .lb:not(.is-static) .lb-leaf-l .lb-stroke { animation: lb-trace 0.65s cubic-bezier(0.5, 0, 0.4, 1) 0.7s forwards, lb-sfade 0.3s ease 1.3s forwards; }
  .lb:not(.is-static) .lb-leaf-l .lb-fill { animation: lb-ink 0.35s ease 1.15s forwards; }

  /* right leaf: 0.73 - 1.53s */
  .lb:not(.is-static) .lb-leaf-r { animation: lb-grow 0.7s cubic-bezier(0.34, 1.3, 0.64, 1) 0.73s both; }
  .lb:not(.is-static) .lb-leaf-r .lb-stroke { animation: lb-trace 0.65s cubic-bezier(0.5, 0, 0.4, 1) 0.78s forwards, lb-sfade 0.3s ease 1.38s forwards; }
  .lb:not(.is-static) .lb-leaf-r .lb-fill { animation: lb-ink 0.35s ease 1.23s forwards; }

  /* central leaf: 0.95 - 1.78s */
  .lb:not(.is-static) .lb-leaf-t { animation: lb-grow-t 0.8s cubic-bezier(0.18, 1, 0.32, 1) 0.95s both; }
  .lb:not(.is-static) .lb-leaf-t .lb-stroke { animation: lb-trace 0.7s cubic-bezier(0.5, 0, 0.4, 1) 1s forwards, lb-sfade 0.3s ease 1.65s forwards; }
  .lb:not(.is-static) .lb-leaf-t .lb-fill { animation: lb-ink 0.4s ease 1.45s forwards; }
  @keyframes lb-grow { from { transform: scale(0); } to { transform: none; } }
  @keyframes lb-grow-t { from { transform: scaleX(0.42) scaleY(0); } to { transform: none; } }

  @keyframes lb-trace { to { stroke-dashoffset: 0; } }
  @keyframes lb-sfade { to { opacity: 0; } }
  @keyframes lb-ink { to { opacity: 1; } }

  /* settle */
  .lb:not(.is-static) .lb-root {
    transform-box: view-box;
    transform-origin: 215px 540px;
    animation: lb-breathe 7s ease-in-out 2.0s infinite;
  }
  @keyframes lb-breathe {
    0%, 100% { transform: scale(1); }
    50%      { transform: scale(1.012); }
  }

  @media (prefers-reduced-motion: reduce) {
    .lb .lb-piece, .lb .lb-fill, .lb .lb-stroke, .lb .lb-root { animation: none; }
    .lb .lb-piece { transform: none; }
    .lb .lb-fill { opacity: 1; }
    .lb .lb-stroke { display: none; }
  }
</style>
