---
// "One spine": the mark is a single continuous element — a spine that rises
// from the ground, curls into the foot at the base, runs up the column, and
// at its tip widens into the pointed leaf (the leaf IS the stem's growing
// end, not a separate piece). Two side leaves branch off the spine at the
// neck. The spine grows by a single bottom-up reveal; the side leaves unfurl
// from where they meet it. A first pass, meant to be iterated.
interface Props {
  size?: number;
  static?: boolean;
}
const { size = 220, static: isStatic = false } = Astro.props;
const width = Math.round((size * 220) / 280);
const uid = Math.random().toString(36).slice(2, 9);
const revealId = `ls-reveal-${uid}`;

// One continuous shape: pointed leaf at top -> column -> foot-hook at the base.
const spineD =
  "M 110 16 C 124 28, 146 88, 122 130 C 121 155, 120 180, 120 200 C 119 218, 124 230, 142 234 C 152 236, 159 233, 162 226 C 167 225, 169 232, 169 238 C 169 244, 166 250, 161 250 C 152 256, 140 258, 128 256 C 108 251, 97 240, 95 218 C 95 211, 97 207, 99 200 C 98 180, 97 155, 98 130 C 74 88, 96 28, 110 16 Z";
// Side leaves, branching off the spine at the neck (~y130).
const leafLeftD = "M 99 134 C 78 128, 48 136, 28 164 C 48 154, 76 146, 100 144 Z";
const leafRightD = "M 121 134 C 142 128, 172 136, 192 164 C 172 154, 144 146, 120 144 Z";
---

<svg
  class:list={["ls", { "is-static": isStatic }]}
  width={width}
  height={size}
  viewBox="0 0 220 280"
  xmlns="http://www.w3.org/2000/svg"
  aria-label="Tend"
  role="img"
>
  <defs>
    <clipPath id={revealId} clipPathUnits="userSpaceOnUse">
      <rect class="ls-reveal-rect" x="0" y="0" width="220" height="300"></rect>
    </clipPath>
  </defs>
  <g class="ls-root">
    <path class="ls-spine" d={spineD} clip-path={`url(#${revealId})`}></path>
    <g class="ls-leaf ls-leaf-l">
      <path class="ls-fill" d={leafLeftD}></path>
      <path class="ls-stroke" d={leafLeftD} fill="none" stroke="currentColor" stroke-width="3" stroke-linejoin="round" stroke-linecap="round" pathLength="1"></path>
    </g>
    <g class="ls-leaf ls-leaf-r">
      <path class="ls-fill" d={leafRightD}></path>
      <path class="ls-stroke" d={leafRightD} fill="none" stroke="currentColor" stroke-width="3" stroke-linejoin="round" stroke-linecap="round" pathLength="1"></path>
    </g>
  </g>
</svg>

<style>
  .ls {
    display: block;
    overflow: visible;
    color: var(--oak, #b5a48a);
  }
  .ls-spine, .ls-fill { fill: currentColor; }
  .ls-stroke { fill: none; }

  .ls .ls-leaf-l { transform-box: view-box; transform-origin: 99px 139px; }
  .ls .ls-leaf-r { transform-box: view-box; transform-origin: 121px 139px; }

  /* ---- entrance --------------------------------------------------------
   * The spine reveals in one bottom-up sweep — the foot, then the column
   * rising, then the leaf-blade opening to its point. Once the sweep has
   * passed the neck, the two side leaves unfurl from where they meet it.
   * -------------------------------------------------------------------- */
  .ls:not(.is-static) .ls-reveal-rect {
    /* start fully below the mark (nothing shown), slide up to reveal */
    transform: translateY(258px);
    animation: ls-reveal 1.15s cubic-bezier(0.4, 0.1, 0.3, 1) 0.05s forwards;
  }
  @keyframes ls-reveal {
    to { transform: translateY(0); }
  }

  .ls:not(.is-static) .ls-fill { opacity: 0; }
  .ls:not(.is-static) .ls-stroke { stroke-dasharray: 1; stroke-dashoffset: 1; }

  .ls:not(.is-static) .ls-leaf-l { animation: ls-open 0.7s cubic-bezier(0.34, 1.3, 0.64, 1) 0.7s both; }
  .ls:not(.is-static) .ls-leaf-r { animation: ls-open 0.7s cubic-bezier(0.34, 1.3, 0.64, 1) 0.78s both; }
  @keyframes ls-open { from { transform: scale(0.04); } to { transform: none; } }

  .ls:not(.is-static) .ls-leaf-l .ls-stroke { animation: ls-trace 0.66s cubic-bezier(0.5, 0, 0.4, 1) 0.74s forwards, ls-sfade 0.3s ease 1.36s forwards; }
  .ls:not(.is-static) .ls-leaf-r .ls-stroke { animation: ls-trace 0.66s cubic-bezier(0.5, 0, 0.4, 1) 0.82s forwards, ls-sfade 0.3s ease 1.44s forwards; }
  .ls:not(.is-static) .ls-leaf-l .ls-fill { animation: ls-ink 0.35s ease 1.12s forwards; }
  .ls:not(.is-static) .ls-leaf-r .ls-fill { animation: ls-ink 0.35s ease 1.2s forwards; }
  @keyframes ls-trace { to { stroke-dashoffset: 0; } }
  @keyframes ls-sfade { to { opacity: 0; } }
  @keyframes ls-ink { to { opacity: 1; } }

  /* settle */
  .ls:not(.is-static) .ls-root {
    transform-box: view-box;
    transform-origin: 110px 250px;
    animation: ls-breathe 7s ease-in-out 2.0s infinite;
  }
  @keyframes ls-breathe {
    0%, 100% { transform: scale(1); }
    50%      { transform: scale(1.012); }
  }

  @media (prefers-reduced-motion: reduce) {
    .ls .ls-reveal-rect, .ls .ls-leaf, .ls .ls-fill, .ls .ls-stroke, .ls .ls-root { animation: none; }
    .ls .ls-reveal-rect { transform: none; }
    .ls .ls-leaf { transform: none; }
    .ls .ls-fill { opacity: 1; }
    .ls .ls-stroke { display: none; }
  }
</style>
